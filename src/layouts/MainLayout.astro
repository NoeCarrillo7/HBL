---

//En este archivo es el layout en el cual se ponen los estilos generales del proyecto como 
//el color del fondo, tipo de letras, colores generales, etc. ademas se agregan los componente compartidos 
//para que aparezcan en cada pagina sin tener que volverlos a llamar como el nav-bar y el footer

import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
}
const { title } = Astro.props;
---





<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <style is:global>
            body { background-color: #000; color: #fff; font-family: sans-serif; }
            a { color: #fff; text-decoration: none; }
            .active { color: #7c3aed !important; font-weight: bold; }
        </style>
    </head>

    <body>
        <Navbar />
        <slot /> <Footer />
    </body>
</html>