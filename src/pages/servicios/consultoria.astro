---
import MainLayout from '../../layouts/MainLayout.astro';
import HeroServicios from '../../components/HeroServicios.astro';
import Contacto from '../../components/Contacto.astro';


import Consulatoria from '../../assets/servicios/Consultoria.png';


const servicios = [
  "AUDITORÍA DE PRESENCIA DIGITAL",
  "ANÁLISIS DE COMPETENCIA",
  "ESTRATEGIA DE MARCA",
  "DISEÑO DE EXPERIENCIA DEL CLIENTE (CUSTOMER JOURNEY)",
  "SOCIAL MEDIA Y CONTENIDO",
  "AUDITORÍA DE MARCA Y PUNTOS DE CONTACTO",
  "PLANIFICACIÓN DE CAMPAÑAS O LANZAMIENTOS",
  "RECOMENDACIONES SENSORIALES",
  "CONSULTORÍA PARA EMPRENDEDORES Y CREATIVOS",
  "ACOMPAÑAMIENTO ESTRATÉGICO MENSUAL"
];  
---

<MainLayout title="HBL - ASESORIA">
  <HeroServicios servicioActivo="consultoria" />
  <main class="flex flex-col items-center">
    <div class="w-4/5 mb-10 mt-20 md:mt-30  grid grid-cols-1 md:grid-cols-2">
      <div class="flex flex-col space-y-8">
        <div class="">
          <h1 class="asesoria-titulo text-2xl md:text-4xl font-bold mb-5 tracking-wider">
            ASESORIA 1:1 <br><span class="text-titulos md:text-3xl">ESTRATEGIAS PERSONALIZADAS</span>
          </h1>
          <p class="asesoria-texto text-textos font-normal text-xs md:text-lg tracking-wide leading-relaxed">
            Analizamos tu negocio y diseñamos una estrategia personalizada para impulsar su crecimiento y alcanzar tus objetivos.
          </p>
        </div>

        <div class="md:mt-20 flex justify-center">
          <div class="carrusel-contenedor md:w-4/5">
            <div class="carrusel-track">
              {/* Bloque Original */}
              <div class="carrusel-grupo">
                {servicios.map((servicio) => (
                  <div class="card">{servicio}</div>
                ))}
              </div>
              
              {/* Duplicado idéntico para el efecto infinito */}
              <div class="carrusel-grupo" aria-hidden="true">
                {servicios.map((servicio) => (
                  <div class="card">{servicio}</div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 grid-rows-1 items-center justify-center relative w-full mt-10 md:mt-0">
        <div class="col-start-1 row-start-1 max-w-md md:max-w-full justify-self-center">
          <img 
            src={Consulatoria.src}
            alt="Sesión de asesoría" 
            class="asesoria-img w-full h-auto object-contain"
          />
        </div>

        <a 
          href="https://calendar.app.google/3YUZ9xehuXmA92ke8" 
          class="asesoria-btn col-start-1 row-start-1 z-10 w-32 h-32 md:w-50 md:h-50 rounded-full border border-white bg-black/80 hover:bg-principal hover:border-white transition-all duration-300 flex items-center justify-center text-center p-4 group shadow-xl self-end justify-self-start mb-40 ml-40 md:mb-10 md:-ml-20"
        >
          <span class="text-sm md:text-base font-semibold tracking-wide text-white group-hover:scale-105 transition-transform duration-200">
            Agenda una reunión
          </span>
        </a>
      </div>
    </div>
  </main>
  <Contacto/>
</MainLayout>




<style>
  /* Contenedor principal: define la altura visible y oculta el desborde */
  .carrusel-contenedor {
    height: 100px; /* Ajusta esta altura según cuántas cards quieras ver a la vez */
    overflow: hidden;
    position: relative;
    background: #0a0a0a;
    border-radius: 8px;
    padding: 1rem 0;
  }

  /* Contenedor móvil que aloja ambos grupos */
  .carrusel-track {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    animation: scrollArriba 25s linear infinite;
  }

  /* Pausar el movimiento cuando el usuario pasa el mouse por encima */
  .carrusel-contenedor:hover .carrusel-track {
    animation-play-state: paused;
  }

  /* Grupo de elementos */
  .carrusel-grupo {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Estilo básico de la Card */
  .card {
    background: #141414;
    color: #ffffff;
    padding: 1.5rem;
    margin: 0 1rem;
    border-radius: 6px;
    border: 1px solid #222;
    font-family: system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 500;
    text-align: center;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
  }

  /* Animación CSS: traslada exactamente el 50% de la altura total del track */
  @keyframes scrollArriba {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(calc(-50% - 0.5rem)); /* Resta la mitad del gap para evitar saltos */
    }
  }
  .asesoria-titulo,
.asesoria-texto,
.asesoria-img,
.asesoria-btn {
  opacity: 0;
  transition: all .8s ease;
}

/* Título desde la izquierda */
.asesoria-titulo {
  transform: translateX(-80px);
}

/* Texto desde abajo */
.asesoria-texto {
  transform: translateY(40px);
}

/* Imagen con zoom */
.asesoria-img {
  transform: scale(.8);
}

/* Botón con zoom */
.asesoria-btn {
  transform: scale(.5);
}

.asesoria-visible {
  opacity: 1;
  transform: none;
}
</style>
<script>
document.addEventListener("DOMContentLoaded", () => {

  const titulo = document.querySelector(".asesoria-titulo");
  const texto = document.querySelector(".asesoria-texto");
  const imagen = document.querySelector(".asesoria-img");
  const boton = document.querySelector(".asesoria-btn");

  const observer = new IntersectionObserver((entries) => {

    entries.forEach((entry) => {

      if (entry.isIntersecting) {

        titulo?.classList.add("asesoria-visible");

        setTimeout(() => {
          texto?.classList.add("asesoria-visible");
        }, 200);

        setTimeout(() => {
          imagen?.classList.add("asesoria-visible");
        }, 500);

        setTimeout(() => {
          boton?.classList.add("asesoria-visible");
        }, 800);

      } else {

        titulo?.classList.remove("asesoria-visible");
        texto?.classList.remove("asesoria-visible");
        imagen?.classList.remove("asesoria-visible");
        boton?.classList.remove("asesoria-visible");

      }

    });

  }, {
    threshold: 0.3
  });

  if (titulo) {
    observer.observe(titulo);
  }

});
</script>