<style>
  .carrusel-contenedor {
    overflow: hidden;
    width: 100%;
    margin: 0 auto;
    mask-image: linear-gradient(
      to right,
      transparent,
      #000 10%,
      #000 90%,
      transparent
    );
  }

  .carrusel-track {
    display: flex;
    gap: 20px;
    width: max-content;
    animation: scroll-automatico 25s linear infinite;
  }

  .carrusel-track:hover {
    animation-play-state: paused;
  }

  .card-item {
    position: relative;
    flex: 0 0 300px;
    height: 400px;
    border: 1px solid var(--color-principal);
    border-radius: 5px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: #222;
  }

  .card-bg-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1; /* Capa más baja */
  }

  .card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.9) 20%,
      rgba(0, 0, 0, 0.4) 100%
    );
    z-index: 2;
  }

  .card-img {
    width: 100%;
    height: 150px;
    object-fit: cover;
    background: #eee;
  }

  .card-contenido {
    position: relative;
    z-index: 3;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .creditos {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
    color: var(--color-titulos);
  }

  h3 {
    margin: 0;
    font-size: 1.3rem;
    font-weight: 700;
  }

  ul {
    margin: 0;
    padding-left: 16px;
  }

  li {
    font-size: 0.7rem;
    color: var(--color-textos);
    margin-bottom: 4px;
    line-height: 1.3;
  }
  .branding-info {
    opacity: 0;
    transform: translateX(-80px);
    transition: all 0.8s ease;
  }

.branding-paquete {
  opacity: 0;
  transform: translateY(60px);
  transition: all 0.8s ease;
}
.branding-visible {
  opacity: 1;
  transform: translateY(0);
}
  .creditos-titulo {
  opacity: 0;
  transform: translateX(-60px);
  transition: all .8s ease;
}

.creditos-texto {
  opacity: 0;
  transform: translateY(40px);
  transition: all .8s ease;
}

.creditos-visible {
  opacity: 1;
  transform: none;
}

  @keyframes scroll-automatico {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
<script>
document.addEventListener("DOMContentLoaded", () => {

  const info = document.querySelector(".branding-info");
  const cards = document.querySelectorAll(".branding-paquete");

  const titulo = document.querySelector(".creditos-titulo");
  const texto = document.querySelector(".creditos-texto");

  const observer = new IntersectionObserver((entries) => {

    entries.forEach((entry) => {

      // INFO BRANDING
      if (entry.target === info) {

        if (entry.isIntersecting) {
          info.classList.add("branding-visible");
        } else {
          info.classList.remove("branding-visible");
        }

      }

      // PAQUETES
      if (cards.length > 0 && entry.target === cards[0]) {

        if (entry.isIntersecting) {

          cards.forEach((card, index) => {
            setTimeout(() => {
              card.classList.add("branding-visible");
            }, index * 300);
          });

        } else {

          cards.forEach((card) => {
            card.classList.remove("branding-visible");
          });

        }

      }

      // CRÉDITOS
      if (entry.target === titulo) {

        if (entry.isIntersecting) {

          titulo.classList.add("creditos-visible");

          setTimeout(() => {
            texto?.classList.add("creditos-visible");
          }, 250);

        } else {

          titulo.classList.remove("creditos-visible");
          texto?.classList.remove("creditos-visible");

        }

      }

    });

  }, {
    threshold: 0.3
  });

  if (info) observer.observe(info);

  if (cards.length > 0) {
    observer.observe(cards[0]);
  }

  if (titulo) observer.observe(titulo);

});
</script>