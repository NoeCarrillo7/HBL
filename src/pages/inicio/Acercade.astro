---
// src/components/Acercade.astro

import imagen1 from "../../assets/acercade/seccion1.png";
import imagen2 from "../../assets/acercade/seccion2.png";
---

<section id="acercade"  class="pb-24 flex flex-col items-center mt-10">
  <div class="w-4/5 ">
    <!-- SECCIÓN 1 -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-20 items-center mt-10">
      <div class="acerca-img-left  order-2 md:order-1">
        <!-- IMAGEN 1 -->
        <img
          src={imagen1.src}
          alt="Acerca de HBL"
          class="w-full md:h-[400px] object-cover rounded-xl brightness-75 hover:brightness-100 transition duration-500"
        />
      </div>

      <div class="acerca-text-right order-1 md:order-2">
        <h2 class="text-2xl md:text-4xl font-bold tracking-wider">
          TU HISTORIA
          <span class="text-titulos"> NUESTRA INSPIRACIÓN </span>
        </h2>
        <!-- texto 1 -->
        <div class="text-textos text-xs md:text-base mt-8 tracking-wide space-y-2 md:leading-7 text-justify">
          <p>
            Sabemos que cada marca es única y tiene necesidades específicas. Por
            eso, en HORECA BRANDING LAB ofrecemos total flexibilidad para
            adaptar nuestros servicios y crear un plan personalizado.
          </p>

          <p>
            Combinando únicamente lo que necesitas y ajustándonos a tus
            objetivos, tiempos y presupuesto.
          </p>

          <p>
            Tanto si estás comenzando como si deseas consolidar o hacer crecer
            tu marca, diseñamos una propuesta ajustada a tu realidad.
          </p>

          <p>
            Cuéntanos qué necesitas y crearemos una solución totalmente a tu
            medida.
          </p>
        </div>
      </div>
    </div>

    <!-- SECCIÓN 2 -->
    <div class="grid lg:grid-cols-2 gap-10 md:gap-20 items-center mt-32">
      <div class="acerca-text-left max-w-xl">
        <!-- titulo 2 -->
        <h2 class="text-2xl md:text-4xl font-bold tracking-wider">
          QUIÉNES
          <span class="text-titulos">SOMOS</span>
        </h2>
        <!-- TEXTO 2 -->
        <div
          class="text-textos text-xs md:text-base mt-8 tracking-wide space-y-2 md:leading-7 text-justify"
        >
          <p>
            En HORECA BRANDING LAB somos un equipo multidisciplinario
            especializado en el sector HORECA.
          </p>
          <p>
            Combinamos creatividad, estrategia y conocimiento para construir
            marcas sólidas, auténticas y con propósito.
          </p>
          <p>
            Diseñamos experiencias de marca que conectan, diferencian y hacen
            crecer tu negocio.
          </p>
        </div>
      </div>
      <!-- IMAGEN 2 -->
      <div class="acerca-img-right">
        <img
          src={imagen2.src}
          alt="Quiénes somos"
          class="w-full md:h-[400px] object-cover rounded-3xl brightness-75 hover:brightness-100 transition duration-500"
        />
      </div>
    </div>
  </div>
</section>
<style>
.acerca-img-left,
.acerca-img-right,
.acerca-text-left,
.acerca-text-right {
  opacity: 0;
  transition: all 1s ease;
}

.acerca-img-left {
  transform: translateX(-100px);
}

.acerca-text-right {
  transform: translateX(100px);
}

.acerca-text-left {
  transform: translateX(-100px);
}

.acerca-img-right {
  transform: translateX(100px);
}

.acerca-visible {
  opacity: 1;
  transform: translateX(0);
}
</style>
<script>
document.addEventListener("DOMContentLoaded", () => {

  const elementos = document.querySelectorAll(
    ".acerca-img-left, .acerca-img-right, .acerca-text-left, .acerca-text-right"
  );

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {

        if (entry.isIntersecting) {
          entry.target.classList.add("acerca-visible");
        } else {
          entry.target.classList.remove("acerca-visible");
        }

      });
    },
    {
      threshold: 0.2,
    }
  );

  elementos.forEach((el) => observer.observe(el));
});
</script>