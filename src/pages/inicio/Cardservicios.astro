<style>
    .card {
        position: absolute;
        inset: 0;
        border-radius: 1.5rem;
        opacity: 0;
        transform: scale(0.95) translateY(40px);
        transition: all 0.6s ease;
        pointer-events: none;
    }

    .card.active {
        opacity: 1;
        transform: scale(1) translateY(0);
        z-index: 50;
        pointer-events: auto;
    }

    .card:nth-child(1) {
        z-index: 6;
    }
    .card:nth-child(2) {
        z-index: 5;
    }
    .card:nth-child(3) {
        z-index: 4;
    }
    .card:nth-child(4) {
        z-index: 3;
    }
    .card:nth-child(5) {
        z-index: 2;
    }
    .card:nth-child(6) {
        z-index: 1;
    }
    .anim-titulo {
        opacity: 0;
        transform: translateY(50px);
        transition: all 0.8s ease;
    }

    .anim-texto {
        opacity: 0;
        transform: translateY(50px);
        transition: all 0.8s ease;
    }

    .anim-visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<!-- FUNCIONALIDAD DE LAS CARD -->
<script>
    document.addEventListener("DOMContentLoaded", () => {
        // ANIMACIÓN H2 Y P
        const titulo = document.querySelector(".anim-titulo");
        const texto = document.querySelector(".anim-texto");

        if (titulo && texto) {
            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            titulo.classList.add("anim-visible");

                            setTimeout(() => {
                                texto.classList.add("anim-visible");
                            }, 300);
                        } else {
                            titulo.classList.remove("anim-visible");
                            texto.classList.remove("anim-visible");
                        }
                    });
                },
                {
                    threshold: 0.3,
                },
            );

            observer.observe(titulo);
        }

        // EFECTO CARDS SCROLL
        const section = document.querySelector("section");
        const cards = document.querySelectorAll(".card");

        window.addEventListener("scroll", () => {
            if (!section || cards.length === 0) return;

            const rect = section.getBoundingClientRect();

            const progress = Math.min(
                1,
                Math.max(
                    0,
                    -rect.top / (section.offsetHeight - window.innerHeight),
                ),
            );

            const index = Math.min(
                cards.length - 1,
                Math.floor(progress * cards.length),
            );

            cards.forEach((card, i) => {
                card.classList.toggle("active", i === index);
            });
        });
    });
</script>
