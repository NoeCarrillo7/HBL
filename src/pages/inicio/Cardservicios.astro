                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- SECCION PARA MOVIL -->

    <div class="flex flex-col items-center gap-4 md:hidden">
        <!-- CONTENEDOR DE LAS CARDS -->
        <div class="w-4/5 mt-15 flex flex-col gap-4 md:hidden">
            <!-- CARD 1 -->
            <a
                href="/servicios/branding"
                class="relative h-[280px] rounded-3xl overflow-hidden bg-cover bg-center"
                style={`background-image:url(${c1.src})`}
            >
                <div class="absolute inset-0 bg-black/80"></div>

                <div class="relative p-6 h-full flex flex-col justify-end">
                    <h3 class="text-lg font-bold">
                        BRANDING - <span class="text-titulos"
                            >IDENTIDAD DE MARCA</span
                        >
                    </h3>
                    <p class="text-sm text-textos">
                        No todos los negocios necesitan lo mismo...
                    </p>
                    <span class="text-xs md:text-lg text-titulos"
