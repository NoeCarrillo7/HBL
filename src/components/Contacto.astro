---
// src/components/Contacto.astro

const servicios = [
  "Branding",
  "Social Media",
  "Fotografia",
  "Marketing",
  "Desarrollo Web",
  "Consultoria",
];
---

<section id="contacto" class="py-12">
  <div class="w-4/5 mx-auto">
    <!-- TITULO -->

    <div class="text-center mb-8">
      <h2
        class="contacto-h2 text-white text-1xl md:text-4xl lg:text-4xl font-semibold md:font-bold uppercase tracking-wider"
      >
        Queremos saber más de ti.
      </h2>

      <h3
        class="contacto-h3 text-titulos text-1xl md:text-4xl lg:text-4xl font-extrabold uppercase md:mt-3"
      >
        Contáctanos
      </h3>
    </div>

    <div class="contacto-form grid lg:grid-cols-[320px_1fr] gap-4 lg:gap-6">
      <!-- RECUADRO HABLEMOS-->
      <div class="border border-principal rounded-xl p-5 px-10">
        <h4 class="text-titulos text-1xl font-light mb-8">Hablemos</h4>

        <div class="space-y-3">
          <div class="flex items-start gap-2">
            <i class="fa-solid fa-phone text-titulos text-lg mt-1"></i>
            <div>
              <p class="font-light text-sm">Teléfono</p>
              <p class="text-textos text-xs font-light">+52 614 838 4971</p>
            </div>
          </div>

          <div class="flex items-start gap-2">
            <i class="fa-solid fa-envelope text-titulos text-lg mt-1"></i>
            <div>
              <p class="font-light text-sm">Correo electrónico</p>
              <p class="text-textos text-xs font-light break-all">
                horecabrandinglab@gmail.com
              </p>
            </div>
          </div>

          <div class="flex items-start gap-2">
            <i class="fa-solid fa-location-dot text-titulos text-lg mt-1"></i>
            <div>
              <p class="font-light text-sm">Ubicación</p>
              <p class="text-textos text-xs font-light">Querétaro, México</p>
            </div>
          </div>
        </div>

        <button 
          onclick="window.open('https://wa.me/+526148384971?text=¡Hola! Quiero contratar un servicio.', '_blank', 'noopener,noreferrer')"
          class="mt-10 w-full py-2 rounded-xl border border-[#8B5CF6] text-white font-light hover:bg-[#8B5CF6] transition-all duration-300">
          Contáctanos por
          <i class="fa-brands fa-whatsapp"></i>
        </button>
      </div>

      <!-- FORMULARIO -->
      <form id="contactForm" class="space-y-3">
        <div class="grid md:grid-cols-2 gap-2">
          <input
            type="text"
            id="nombre"
            name="nombre"
            placeholder="Nombre Completo"
            class="input-contacto"
            required
          />

          <input
            type="text"
            id="empresa"
            name="empresa"
            placeholder="Nombre de la empresa"
            class="input-contacto"
          />

          <input
            type="tel"
            id="telefono"
            name="telefono"
            placeholder="Número de teléfono"
            class="input-contacto"
          />

          <input
            type="email"
            id="correo"
            name="correo"
            placeholder="Correo electrónico"
            class="input-contacto"
            required
          />
        </div>

        <div class="input-contacto">
          <p class="text-textos text-sm mb-2">Servicios que te interesan</p>

          <div class="flex flex-wrap gap-2">
            {
              servicios.map((servicio) => (
                <label class="cursor-pointer">
                  {}
                  <input 
                    type="checkbox" 
                    name="servicios[]" 
                    value={servicio} 
                    class="peer hidden" 
                  />

                  <span
                    class="px-3 py-1 border border-purple-500/40 rounded-full text-white text-sm 
                    hover:bg-purple-500/10 transition 
                    peer-checked:bg-purple-500 peer-checked:text-white"
                  >
                    {servicio}
                  </span>
                </label>
              ))
            }
          </div>
        </div>

        <textarea
          id="mensaje"
          name="mensaje"
          rows="4"
          placeholder="Cuéntanos sobre tu proyecto"
          class="input-contacto resize-none"
          required></textarea>

        <button
          type="submit"
          class="w-full py-2 md:py-5 rounded-[5px] font-light5 uppercase text-white bg-gradient-to-r from-titulos to-[#4F119F] hover:scale-[1.01] transition-all duration-300"
        >
          Enviar información
        </button>

        <p id="formResponse" class="text-center text-sm font-semibold hidden py-2"></p>

        <p class="text-center text-textos text-xs md:text-sm">
          <i class="fa-solid fa-user-shield text-titulos"></i>
          Tu información está segura con nosotros
        </p>
      </form>
    </div>
  </div>
</section>

<style>
  .input-contacto {
    width: 100%;
    border: 1px solid var(--color-principal);
    border-radius: 5px;
    padding: 0.7rem 2rem;
    color: white;
    outline: none;
    transition: all 0.3s ease;
  }

  .input-contacto::placeholder {
    color: var(--color-textos);
    font-size: 0.875rem;
  }

  .input-contacto:focus {
    border-color: rgb(139, 92, 246);
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.2);
  }

  .input-contacto option {
    background: #111;
    color: white;
  }
  .contacto-h2 {
    opacity: 0;
    transform: translateY(-50px);
    transition: all 0.8s ease;
  }

  .contacto-h3 {
    opacity: 0;
    transform: translateY(50px);
    transition: all 0.8s ease;
  }

  .contacto-form {
    opacity: 0;
    transform: scale(0.9);
    transition: all 1s ease;
  }

  .contacto-visible {
    opacity: 1;
    transform: none;
  }
</style>


<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contactForm') as HTMLFormElement;
    const responseMessage = document.getElementById('formResponse');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const checkboxes = document.querySelectorAll('input[name="servicios[]"]:checked') as NodeListOf<HTMLInputElement>;
      const serviciosSeleccionados = Array.from(checkboxes).map(cb => cb.value);

      const formData = {
        nombre: (document.getElementById('nombre') as HTMLInputElement).value,
        empresa: (document.getElementById('empresa') as HTMLInputElement).value,
        telefono: (document.getElementById('telefono') as HTMLInputElement).value,
        correo: (document.getElementById('correo') as HTMLInputElement).value,
        servicios: serviciosSeleccionados,
        mensaje: (document.getElementById('mensaje') as HTMLTextAreaElement).value,
      };

      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (submitBtn) submitBtn.disabled = true;

      if (responseMessage) {
        responseMessage.classList.remove('hidden');
        responseMessage.style.color = '#c084fc';
        responseMessage.textContent = 'Enviando información...';
      }

      try {
        const response = await fetch('/enviar.php', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(formData),
        });

        if (!response.ok) {
          throw new Error('Error en la respuesta del servidor');
        }

        const result = await response.json();

        if (responseMessage) {
          if (result.status === 'success') {
            responseMessage.style.color = '#22c55e';
            responseMessage.innerHTML =  `<i class="fa-solid fa-circle-check mr-2"></i> ¡Mensaje recibido con éxito! <br/> Pronto nos comunicaremos contigo para agendar una llamada de 30 minutos, conocer tu proyecto y adaptarnos a tus horarios.`;
            form.reset();
          } else {
            responseMessage.style.color = '#ef4444';
          }
        }
      } catch (error) {
        if (responseMessage) {
          responseMessage.style.color = '#ef4444';
          responseMessage.innerHTML =  `<i class="fa-solid fa-circle-exclamation mr-2"></i> Hubo un error, intentalo de nuevo o contactanos por Whatsapp. `;
        }
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  });


  document.addEventListener("DOMContentLoaded", () => {

  const h2 = document.querySelector(".contacto-h2");
  const h3 = document.querySelector(".contacto-h3");
  const form = document.querySelector(".contacto-form");

  if (!h2 || !h3 || !form) return;

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {

      if (entry.isIntersecting) {

        h2.classList.add("contacto-visible");

        setTimeout(() => {
          h3.classList.add("contacto-visible");
        }, 200);

        setTimeout(() => {
          form.classList.add("contacto-visible");
        }, 400);

      } else {

        h2.classList.remove("contacto-visible");
        h3.classList.remove("contacto-visible");
        form.classList.remove("contacto-visible");

      }

    });
  }, {
    threshold: 0.3
  });

  observer.observe(h2);

});
</script>
