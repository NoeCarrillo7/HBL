---
import logo from '../assets/footer/logoblanco.png';
import fond from '../assets/footer/fondo.png';
---

<footer
  id="footer"
  class="relative overflow-hidden px-8 py-8 bg-cover bg-center bg-no-repeat"
  style={`background-image: url(${fond.src});`}
>
  <div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 text-center md:text-left">

    <div class="footer-logo flex justify-center md:justify-start">
      <img
        src={logo.src}
        alt="HBL"
         class="w-20 md:w-24 pt-0 md:pt-16"
      />
    </div>

    <div class="footer-item">
      <h4 class="text-white text-xl font-medium mb-4">
        LINKS
      </h4>

      <div class="flex flex-col gap-3">
        <a href="/" class="hover:text-white transition">
          Inicio
        </a>

        <a href="/servicios/branding" class="hover:text-white transition">
          Servicios
        </a>

        <a href="#contacto" class="hover:text-white transition">
          Contáctanos
        </a>
      </div>
    </div>

    <div class="footer-item">
      <h4 class="text-white text-xl font-medium mb-4">
        SOCIAL
      </h4>

      <div class="flex justify-center md:justify-start gap-8 text-xl">
        <a
          href="#"
          class="text-zinc-300 hover:text-white transition"
        >
          <i class="fa-brands fa-instagram"></i>
        </a>

        <a
          href="#"
          class="text-zinc-300 hover:text-white transition"
        >
          <i class="fa-brands fa-facebook-f"></i>
        </a>
      </div>
    </div>

    <div class="footer-item">
      <h4 class="text-white text-xl font-medium mb-4">
        CONTACTO
      </h4>

      <a href="mailto:horecabrandinglab@gmail.com" class="text-extralight transition ">
        horecabrandinglab@gmail.com
      </a>
    </div>

  </div>

  <div class="footer-bottom mt-12 md:mt-16 text-center text-zinc-400 text-xs px-4">

    <p>
      2026 Horeca Branding Lab. Todos los derechos reservados.
    </p>


    <!--
      <div class="mt-3 flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-4">
      <a href="#" class="text-white hover:text-purple-400">
        Términos y Condiciones
      </a>
      <span class="hidden sm:block">|</span>
      <a href="#" class="text-white hover:text-purple-400">
        Política de Privacidad
      </a>
    </div>
    -->
    

  </div>
</footer>
<style>
.footer-logo,
.footer-item,
.footer-bottom {
  opacity: 0;
  transition: all .8s ease;
}

.footer-logo {
  transform: translateX(-80px);
}

.footer-item {
  transform: translateY(40px);
}

.footer-bottom {
  transform: translateY(30px);
}

.footer-visible {
  opacity: 1;
  transform: none;
}
</style>

<script>
document.addEventListener("DOMContentLoaded", () => {

  const footer = document.getElementById("footer");

  if (!footer) return;

  const logo = footer.querySelector(".footer-logo");
  const items = footer.querySelectorAll(".footer-item");
  const bottom = footer.querySelector(".footer-bottom");

  const observer = new IntersectionObserver((entries) => {

    entries.forEach((entry) => {

      if (entry.isIntersecting) {

        logo?.classList.add("footer-visible");

        items.forEach((item, index) => {
          setTimeout(() => {
            item.classList.add("footer-visible");
          }, 200 + (index * 200));
        });

        setTimeout(() => {
          bottom?.classList.add("footer-visible");
        }, 900);

      } else {

        logo?.classList.remove("footer-visible");

        items.forEach((item) => {
          item.classList.remove("footer-visible");
        });

        bottom?.classList.remove("footer-visible");
      }

    });

  }, {
    threshold: 0.2
  });

  observer.observe(footer);

});
</script>